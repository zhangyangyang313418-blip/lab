          <mxGeometry height="92" width="360" x="70" y="1916" as="geometry" />
        </mxCell>
        <mxCell id="left04b" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#d8dee9;strokeWidth=1.5;shadow=1;fontColor=#1f2937;fontFamily=Microsoft YaHei;fontSize=12;fontStyle=0;align=left;verticalAlign=top;spacing=12;dashed=0;" value="04B 委外资源确认&lt;br&gt;使用人：测试采购人员&lt;br&gt;触发条件：存在委外测试任务包，或内部资源不满足需转委外（委外就会触发新的审批）&lt;div&gt;内部资源不够，实验室负责人可以退回流程，给出可以执行的资源排期，申请人可确认是否修改，若接受则申请单的测试时间可以直接修改，否则完全退单&lt;/div&gt;" vertex="1">
          <mxGeometry height="127" width="360" x="60" y="2093" as="geometry" />
        </mxCell>
        <mxCell id="left05a" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#d8dee9;strokeWidth=1.5;shadow=1;fontColor=#1f2937;fontFamily=Microsoft YaHei;fontSize=12;fontStyle=0;align=left;verticalAlign=top;spacing=12;dashed=0;" value="05A 内部测试执行&lt;br&gt;使用人：东莞实验室测试人员、申请人&lt;br&gt;触发条件：实验室负责人接受申请并分配任务" vertex="1">
          <mxGeometry height="105" width="360" x="40" y="2711" as="geometry" />
        </mxCell>
        <mxCell id="left05b" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#d8dee9;strokeWidth=1.5;shadow=1;fontColor=#1f2937;fontFamily=Microsoft YaHei;fontSize=12;fontStyle=0;align=left;verticalAlign=top;spacing=12;dashed=0;" value="05B 委外测试执行&lt;br&gt;使用人：申请人/产品测试工程师主跟进，采购可查看状态&lt;br&gt;触发条件：采购确认第三方实验室资源" vertex="1">
          <mxGeometry height="105" width="360" x="40" y="2805" as="geometry" />
        </mxCell>
        <mxCell id="left06" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#d8dee9;strokeWidth=1.5;shadow=1;fontColor=#1f2937;fontFamily=Microsoft YaHei;fontSize=12;fontStyle=0;align=left;verticalAlign=top;spacing=12;dashed=0;" value="06 报告归档&lt;br&gt;使用人：申请人、测试人员、系统管理员&lt;br&gt;触发条件：内部草稿确认无误，或第三方报告确认完成" vertex="1">
          <mxGeometry height="110" width="360" x="40" y="3185" as="geometry" />
        </mxCell>
        <mxCell id="right01" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#d8dee9;strokeWidth=1.5;shadow=1;fontColor=#1f2937;fontFamily=Microsoft YaHei;fontSize=12;fontStyle=0;align=left;verticalAlign=top;spacing=12;dashed=0;" value="01 输入 / 输出&lt;br&gt;输入物：&amp;nbsp;&lt;div&gt;一般：OEM(可下拉)/项目(自行编写)/零部件名称/零部件号/样品状态/样品数量/软硬件版本/测试目的（下拉可选）/到样日期/期望完成时间/测试结果是否需要判定/费用归属/报告（中英文选择）/附件（测试搭建&amp;amp;功能说明）&lt;div&gt;特殊：自定义测试条件，除上述内容，需要有明确清晰的测试条件描述及测试限值&amp;amp;判定描述细则&lt;br&gt;输出物：申请清单（自动生成唯一的申请编号）/测试大纲模板（要求可以体现测试时间及测试费用）&lt;br&gt;系统模块：&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;测试申请页面（做了一个展示版本的 HTML，可以看一下）&lt;/li&gt;&lt;li&gt;测试大纲编写页面（三种模式：自定义/测试项目数据库筛选/test flow 模版编辑）&lt;/li&gt;&lt;li&gt;test flow 模板（可以编辑，每个 OEM 一个模板，可以显示测试所需时间，样本量，辅助设备数量，费用，可以导出测试大纲 ）&lt;/li&gt;&lt;li&gt;测试项目数据库（产品测试工程师维护/需要人为筛选 excel 填入，要求测试 ID 唯一性，编写好的 test flow 导出的测试大纲其测试条件来源于这个库/需要有标记，哪个项目可以东莞实验室测试，哪个只能委外）&lt;/li&gt;&lt;li&gt;费用规则（先系统录入计算一次，然后需要人工再次修订）&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="225" width="750" x="1390" y="305" as="geometry" />
        </mxCell>
        <mxCell id="right02" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#d8dee9;strokeWidth=1.5;shadow=1;fontColor=#1f2937;fontFamily=Microsoft YaHei;fontSize=12;fontStyle=0;align=left;verticalAlign=top;spacing=12;dashed=0;" value="02 输入 / 输出&lt;br&gt;输入物：/&lt;br&gt;输出物：信息完整的申请清单&amp;amp;编辑好的测试大纲&amp;amp;费用" vertex="1">
          <mxGeometry height="110" width="740" x="1390" y="645" as="geometry" />
        </mxCell>
        <mxCell id="right03" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#d8dee9;strokeWidth=1.5;shadow=1;fontColor=#1f2937;fontFamily=Microsoft YaHei;fontSize=12;fontStyle=0;align=left;verticalAlign=top;spacing=12;dashed=0;" value="03 输入 / 输出&lt;br&gt;输入物：Test Flow、测试项目属性、内外部测试规则&lt;br&gt;输出物：内部任务包、委外任务包、混合任务包&lt;br&gt;系统模块：分流规则引擎" vertex="1">
          <mxGeometry height="110" width="740" x="1420" y="895" as="geometry" />
        </mxCell>
        <mxCell id="right04a" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#d8dee9;strokeWidth=1.5;shadow=1;fontColor=#1f2937;fontFamily=Microsoft YaHei;fontSize=12;fontStyle=0;align=left;verticalAlign=top;spacing=12;dashed=0;" value="04A 输入 / 输出&lt;br&gt;输入物：内部任务包、样品、测试条件、期望交期&lt;br&gt;输出物：接受申请、退回意见、资源确认结果&lt;br&gt;系统模块：内部实验室资源管理" vertex="1">
          <mxGeometry height="112" width="740" x="1420" y="1755" as="geometry" />
        </mxCell>
        <mxCell id="right04b" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#d8dee9;strokeWidth=1.5;shadow=1;fontColor=#1f2937;fontFamily=Microsoft YaHei;fontSize=12;fontStyle=0;align=left;verticalAlign=top;spacing=12;dashed=0;" value="04B 输入 / 输出&lt;br&gt;输入物：委外任务包、实验室资质要求、候选第三方实验室名单（是否有指定及特殊要求，如现场测试等）/系统隐藏的比价单开放给采购工程师&lt;br&gt;输出物：比价记录（带折扣）、选定实验室、最终定价、周期&lt;br&gt;系统模块：委外采购管理（采购工程师录入比价记录，确认实验室，然后流程反馈给到产品测试工程师和申请人）、第三方实验室库（带评价）" vertex="1">
          <mxGeometry height="112" width="740" x="1420" y="1925" as="geometry" />
        </mxCell>
        <mxCell id="right05a" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#d8dee9;strokeWidth=1.5;shadow=1;fontColor=#1f2937;fontFamily=Microsoft YaHei;fontSize=12;fontStyle=0;align=left;verticalAlign=top;spacing=12;dashed=0;" value="05A 输入 / 输出&lt;br&gt;输入物：内部测试任务、样品、标准、Test Flow&lt;br&gt;输出物：资源看板、原始记录、草稿报告、申请人确认结果&lt;br&gt;系统模块：测试执行、原始记录、报告管理" vertex="1">
          <mxGeometry height="118" width="720" x="1420" y="2260" as="geometry" />
        </mxCell>
        <mxCell id="right05b" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#d8dee9;strokeWidth=1.5;shadow=1;fontColor=#1f2937;fontFamily=Microsoft YaHei;fontSize=12;fontStyle=0;align=left;verticalAlign=top;spacing=12;dashed=0;" value="05B 输入 / 输出&lt;br&gt;输入物：委外任务、第三方实验室信息、第三方报告&lt;br&gt;输出物：委外状态、第三方正式报告、异常记录&lt;br&gt;系统模块：委外任务管理、报告管理" vertex="1">
          <mxGeometry height="112" width="740" x="1410" y="2788" as="geometry" />
        </mxCell>
        <mxCell id="right06" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#d8dee9;strokeWidth=1.5;shadow=1;fontColor=#1f2937;fontFamily=Microsoft YaHei;fontSize=12;fontStyle=0;align=left;verticalAlign=top;spacing=12;dashed=0;" value="06 输入 / 输出&lt;br&gt;输入物：正式报告、原始记录、附件、流程日志&lt;br&gt;输出物：归档档案、报告库、统计数据&lt;br&gt;系统模块：报告归档、权限、数据看板" vertex="1">
