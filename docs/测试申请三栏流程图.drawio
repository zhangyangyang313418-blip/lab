        <mxCell id="left02" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#d8dee9;strokeWidth=1.5;shadow=1;fontColor=#1f2937;fontFamily=Microsoft YaHei;fontSize=12;fontStyle=0;align=left;verticalAlign=top;spacing=12;dashed=0;" value="02 形成 Test Flow&lt;br&gt;使用人：申请人&lt;br&gt;触发条件：测试目的选择完成后，系统加载模板或进入自定义测试项目选择" vertex="1">
