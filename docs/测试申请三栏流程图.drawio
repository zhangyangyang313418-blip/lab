        <mxCell id="left03" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#d8dee9;strokeWidth=1.5;shadow=1;fontColor=#1f2937;fontFamily=Microsoft YaHei;fontSize=12;fontStyle=0;align=left;verticalAlign=top;spacing=12;dashed=0;" value="03 系统筛选分流&lt;br&gt;使用人：系统自动执行，管理员维护规则&lt;br&gt;触发条件：申请人提交 Test Flow及测试大纲" vertex="1">
