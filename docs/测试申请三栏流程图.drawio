        <mxCell id="left01" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#d8dee9;strokeWidth=1.5;shadow=1;fontColor=#1f2937;fontFamily=Microsoft YaHei;fontSize=12;fontStyle=0;align=left;verticalAlign=top;spacing=12;dashed=0;" value="&lt;b&gt;01 测试申请&lt;/b&gt;&lt;br&gt;&lt;i&gt;使用人：&lt;/i&gt;&lt;font&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;研发工程师&lt;/font&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;、&lt;/font&gt;&lt;/font&gt;产品测试工程师、质量工程师、采购工程师&lt;br&gt;&lt;i&gt;触发条件&lt;/i&gt;：研发摸底、DV/PV、型式试验、客户验证、变更验证等需求产生" vertex="1">
          <mxGeometry height="110" width="360" x="40" y="300" as="geometry" />
